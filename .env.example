# ══════════════════════════════════════════════
# Malidata — Variables d'environnement v2
# ══════════════════════════════════════════════
# ⚠️  Ne jamais committer ce fichier dans Git.
#     Vérifie que .gitignore contient bien ".env"

# LLM — Groq
GROQ_API_KEY=gsk_REMPLACE_PAR_TA_VRAIE_CLE

# Redis (valeurs par défaut — ne pas changer sauf config custom)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# RAG
VECTOR_STORE_PATH=/app/storage/faiss_index.idx

# Frontend (CORS)
FRONTEND_URL=http://localhost:5173
